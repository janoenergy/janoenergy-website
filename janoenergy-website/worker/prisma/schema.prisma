generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  role          String         @default("employee")
  department    String?
  avatarUrl     String?        @map("avatar_url")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workflowSteps WorkflowStep[]
  workflows     Workflow[]

  @@map("users")
}

model Project {
  id            Int       @id @default(autoincrement())
  title         String
  titleEn       String?   @map("title_en")
  category      String
  location      String
  locationEn    String?   @map("location_en")
  capacity      String
  description   String?
  descriptionEn String?   @map("description_en")
  imageUrl      String?   @map("image_url")
  status        String    @default("planning")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("projects")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  titleEn     String?   @map("title_en")
  summary     String?
  summaryEn   String?   @map("summary_en")
  content     String
  contentEn   String?   @map("content_en")
  imageUrl    String?   @map("image_url")
  category    String    @default("company")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("news")
}

model Workflow {
  id          Int            @id @default(autoincrement())
  workflowNo  String         @unique @map("workflow_no")
  type        String
  title       String
  applicantId Int            @map("applicant_id")
  amount      Decimal?       @db.Decimal(15, 2)
  description String?
  status      String         @default("pending")
  currentStep Int            @default(1) @map("current_step")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  steps       WorkflowStep[]
  applicant   User           @relation(fields: [applicantId], references: [id])

  @@map("workflows")
}

model WorkflowStep {
  id         Int      @id @default(autoincrement())
  workflowId Int      @map("workflow_id")
  stepNo     Int      @map("step_no")
  approverId Int?     @map("approver_id")
  action     String?
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  approver   User?    @relation(fields: [approverId], references: [id])
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}
