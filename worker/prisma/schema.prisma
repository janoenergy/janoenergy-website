generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  role          String         @default("employee")
  department    String?
  avatarUrl     String?        @map("avatar_url")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workflowSteps WorkflowStep[]
  workflows     Workflow[]

  @@map("users")
}

model Project {
  id            Int       @id @default(autoincrement())
  title         String
  titleEn       String?   @map("title_en")
  category      String
  location      String
  locationEn    String?   @map("location_en")
  capacity      String
  description   String?
  descriptionEn String?   @map("description_en")
  imageUrl      String?   @map("image_url")
  status        String    @default("planning")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("projects")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  titleEn     String?   @map("title_en")
  summary     String?
  summaryEn   String?   @map("summary_en")
  content     String
  contentEn   String?   @map("content_en")
  imageUrl    String?   @map("image_url")
  category    String    @default("company")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("news")
}

model Workflow {
  id          Int            @id @default(autoincrement())
  workflowNo  String         @unique @map("workflow_no")
  type        String
  title       String
  applicantId Int            @map("applicant_id")
  amount      Decimal?       @db.Decimal(15, 2)
  description String?
  status      String         @default("pending")
  currentStep Int            @default(1) @map("current_step")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  steps       WorkflowStep[]
  applicant   User           @relation(fields: [applicantId], references: [id])

  @@map("workflows")
}

model WorkflowStep {
  id         Int      @id @default(autoincrement())
  workflowId Int      @map("workflow_id")
  stepNo     Int      @map("step_no")
  approverId Int?     @map("approver_id")
  action     String?
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  approver   User?    @relation(fields: [approverId], references: [id])
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

// ========== 公司内容管理 ==========

// 公司简介
model CompanyInfo {
  id          Int    @id @default(autoincrement())
  intro       String @db.Text
  introEn     String @map("intro_en") @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_info")
}

// 发展历程
model Milestone {
  id          Int    @id @default(autoincrement())
  year        String
  title       String
  titleEn     String? @map("title_en")
  description String  @db.Text
  descriptionEn String? @map("description_en") @db.Text
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("milestones")
}

// 核心价值观
model CompanyValue {
  id          Int    @id @default(autoincrement())
  title       String
  titleEn     String? @map("title_en")
  description String  @db.Text
  descriptionEn String? @map("description_en") @db.Text
  icon        String? // 图标名称
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_values")
}

// 管理团队
model TeamMember {
  id          Int    @id @default(autoincrement())
  name        String
  nameEn      String? @map("name_en")
  title       String
  titleEn     String? @map("title_en")
  imageUrl    String? @map("image_url")
  education   String? @db.Text
  educationEn String? @map("education_en") @db.Text
  experience  String? @db.Text
  experienceEn String? @map("experience_en") @db.Text
  description String? @db.Text
  descriptionEn String? @map("description_en") @db.Text
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

// 业务板块
model BusinessSection {
  id          Int    @id @default(autoincrement())
  sectionId   String @unique @map("section_id") // development, investment, epc, operation
  title       String
  titleEn     String? @map("title_en")
  subtitle    String?
  subtitleEn  String? @map("subtitle_en")
  description String  @db.Text
  descriptionEn String? @map("description_en") @db.Text
  features    String[] // 特点列表
  featuresEn  String[] @map("features_en")
  imageUrl    String? @map("image_url")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("business_sections")
}

// 资质证书
model Certificate {
  id          Int    @id @default(autoincrement())
  title       String
  titleEn     String? @map("title_en")
  issuer      String
  issuerEn    String? @map("issuer_en")
  issueDate   String  @map("issue_date") // YYYY-MM
  imageUrl    String? @map("image_url")
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("certificates")
}

// 荣誉奖项
model Honor {
  id          Int    @id @default(autoincrement())
  title       String
  titleEn     String? @map("title_en")
  issuer      String
  issuerEn    String? @map("issuer_en")
  year        String  // YYYY
  imageUrl    String? @map("image_url")
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("honors")
}
